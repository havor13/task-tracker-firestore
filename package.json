{
  "name": "task-tracker-firestore",
  "version": "1.0.0",
  "description": "Task Tracker app with Firebase Firestore (CRUD + Search)",
  "main": "src/index.js",
  "homepage": "https://havor13.github.io/task-tracker-firestore",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint ./src --ext .js,.jsx",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,md}\"",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build"
  },
  "keywords": [
    "firebase",
    "firestore",
    "react",
    "crud",
    "task-tracker"
  ],
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "author": "Sampson Havor",
  "license": "MIT",
  "dependencies": {
    "firebase": "^12.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "^0.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-react-app": "^7.0.1",
    "gh-pages": "^6.3.0",
    "prettier": "^3.2.5"
  }
}
